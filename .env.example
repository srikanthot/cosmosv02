# Azure OpenAI (GCC High — openai.azure.us)
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.us/
AZURE_OPENAI_API_KEY=<key>
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_CHAT_DEPLOYMENT=<chat-deployment-name>
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=<chat-deployment-name>
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=<embeddings-deployment-name>

# Azure AI Search (GCC High — search.azure.us)
AZURE_SEARCH_ENDPOINT=https://<search>.search.azure.us
AZURE_SEARCH_API_KEY=<search-key>
AZURE_SEARCH_INDEX=rag-psegtechm-index-finalv2

# Index field mappings — must match rag-psegtechm-index-finalv2 schema exactly
SEARCH_CONTENT_FIELD=chunk
SEARCH_SEMANTIC_CONTENT_FIELD=chunk_for_semantic
SEARCH_VECTOR_FIELD=text_vector
SEARCH_FILENAME_FIELD=source_file
SEARCH_URL_FIELD=source_url
SEARCH_CHUNK_ID_FIELD=chunk_id
SEARCH_TITLE_FIELD=title
SEARCH_SECTION1_FIELD=header_1
SEARCH_SECTION2_FIELD=header_2
SEARCH_SECTION3_FIELD=header_3
# Leave blank — this index has no page number field
SEARCH_PAGE_FIELD=

# Retrieval tuning
TOP_K=5
RETRIEVAL_CANDIDATES=15
VECTOR_K=50

# Retrieval quality
USE_SEMANTIC_RERANKER=true
SEMANTIC_CONFIG_NAME=manual-semantic-config
QUERY_LANGUAGE=en-us
MIN_RESULTS=2
# Gate threshold for base RRF/hybrid scores (range 0.01–0.033)
MIN_AVG_SCORE=0.02
# Gate threshold for semantic reranker scores (range 0.0–4.0); used when USE_SEMANTIC_RERANKER=true
MIN_RERANKER_SCORE=0.3
DIVERSITY_BY_SOURCE=true
MAX_CHUNKS_PER_SOURCE=2
DOMINANT_SOURCE_SCORE_RATIO=1.5
MAX_CHUNKS_DOMINANT_SOURCE=4
SCORE_GAP_MIN_RATIO=0.55
TRACE_MODE=true

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=8501

# Frontend
BACKEND_URL=http://localhost:8000
