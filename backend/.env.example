# =============================================================================
# PSEG Tech Manual Agent — Backend Environment Variables
# =============================================================================
# Copy this file to backend/.env and fill in real values before running locally.
# Never commit the actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure OpenAI (GCC High — openai.azure.us)
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.us
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=<your-chat-deployment>
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=<your-embeddings-deployment>

# -----------------------------------------------------------------------------
# Azure AI Search (GCC High — search.azure.us)
# -----------------------------------------------------------------------------
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.azure.us
AZURE_SEARCH_API_KEY=<your-search-api-key>
AZURE_SEARCH_INDEX=rag-psegtechm-index-finalv2

# -----------------------------------------------------------------------------
# Azure Cosmos DB — Persistent Chat History
# -----------------------------------------------------------------------------
# Auth mode: "key" for local/dev, "managed_identity" for production App Service
COSMOS_AUTH_MODE=key
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_KEY=<your-cosmos-primary-key>

# Database and container names (will be auto-created if COSMOS_AUTO_CREATE_CONTAINERS=true)
COSMOS_DATABASE=ragchatdb
COSMOS_CONVERSATIONS_CONTAINER=conversations
COSMOS_MESSAGES_CONTAINER=messages

# false = use existing containers (created manually in Azure Portal)
# true  = auto-create database and containers on startup (dev/test only)
COSMOS_AUTO_CREATE_CONTAINERS=false

# Max prior messages to inject into LLM context per turn (keeps token count bounded)
COSMOS_HISTORY_MAX_TURNS=12

# TTL — set to true to auto-expire old documents (useful for dev/test)
COSMOS_ENABLE_TTL=false
# TTL in seconds — leave blank to use default 7776000 (90 days)
COSMOS_TTL_SECONDS=

# -----------------------------------------------------------------------------
# Identity — Local Development
# -----------------------------------------------------------------------------
# Used as user_id when no auth headers are present (local testing default)
DEFAULT_LOCAL_USER_ID=local-dev

# -----------------------------------------------------------------------------
# Retrieval Tuning (optional — defaults shown)
# -----------------------------------------------------------------------------
TOP_K=5
RETRIEVAL_CANDIDATES=15
VECTOR_K=50
USE_SEMANTIC_RERANKER=true
SEMANTIC_CONFIG_NAME=manual-semantic-config
MIN_RESULTS=2
MIN_RERANKER_SCORE=0.3
MIN_AVG_SCORE=0.02
DIVERSITY_BY_SOURCE=true
MAX_CHUNKS_PER_SOURCE=2
MAX_CHUNKS_DOMINANT_SOURCE=4
DOMINANT_SOURCE_SCORE_RATIO=1.5
SCORE_GAP_MIN_RATIO=0.55
TRACE_MODE=true

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Local dev — wildcard, no credentials (browser-safe, default):
ALLOWED_ORIGINS=*
#
# Deployed frontend (one or more explicit origins, credentials enabled):
# Streamlit default port is 8501; React/Next default ports are 3000.
# List all origins the browser frontend will be served from.
#
# Example for local Streamlit + future prod:
# ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501,https://myapp.azurewebsites.net
#
# Rule enforced automatically by settings.py:
#   ALLOWED_ORIGINS=*        → allow_credentials=False  (wildcard + creds is invalid per spec)
#   ALLOWED_ORIGINS=explicit → allow_credentials=True   (required for cookie/auth headers)
